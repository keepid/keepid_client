# Copy to `.env.local` and adjust as needed for local dev.

# Server base URL. The legacy Javalin server runs on :7000; the new
# Spring Boot keepid_server_next runs on :7001 and is the default. Set this
# explicitly to point at staging / production / a teammate's tunnel.
#
# Examples:
#   VITE_API_BASE=http://localhost:7001          # keepid_server_next (default)
#   VITE_API_BASE=http://localhost:7000          # legacy keepid_server
#   VITE_API_BASE=https://staged.keep.id         # staging
#
# Resolution order (see src/serverOverride.ts):
#   1. VITE_API_BASE (this file)
#   2. import.meta.env.MODE === 'staging'   → https://staged.keep.id
#   3. import.meta.env.MODE === 'production' → https://server.keep.id
#   4. fallback → http://localhost:7001
VITE_API_BASE=http://localhost:7001

# OAuth client ids — copy from .env if you need OAuth flows locally.
# VITE_GOOGLE_CLIENT_ID=
# VITE_MICROSOFT_CLIENT_ID=
# VITE_MICROSOFT_TENANT_ID=common
