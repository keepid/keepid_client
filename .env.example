# Copy to `.env.local` and adjust as needed for local dev.

# Server base URL. The dockerized keepid_server_next listens on :8080 (per
# its docker-compose.yml `app` service) and is the default. Override only
# if you're running the server differently.
#
# Examples:
#   VITE_API_BASE=http://localhost:8080          # docker-compose (default)
#   VITE_API_BASE=http://localhost:7001          # ./mvnw spring-boot:run
#   VITE_API_BASE=http://localhost:7000          # legacy keepid_server (Javalin)
#   VITE_API_BASE=https://staged.keep.id         # staging
#
# Resolution order (see src/serverOverride.ts):
#   1. VITE_API_BASE (this file)
#   2. import.meta.env.MODE === 'staging'   → https://staged.keep.id
#   3. import.meta.env.MODE === 'production' → https://server.keep.id
#   4. fallback → http://localhost:8080
VITE_API_BASE=http://localhost:8080

# OAuth client ids — copy from .env if you need OAuth flows locally.
# VITE_GOOGLE_CLIENT_ID=
# VITE_MICROSOFT_CLIENT_ID=
# VITE_MICROSOFT_TENANT_ID=common
